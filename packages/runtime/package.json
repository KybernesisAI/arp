{
  "name": "@kybernesis/arp-runtime",
  "version": "0.3.1",
  "description": "ARP runtime — Hono HTTP server, PDP pipeline, connection registry + audit orchestration, per-connection memory partitioning.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/KybernesisAI/arp.git",
    "directory": "packages/runtime"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.5",
    "@kybernesis/arp-audit": "workspace:*",
    "@kybernesis/arp-pdp": "workspace:*",
    "@kybernesis/arp-registry": "workspace:*",
    "@kybernesis/arp-resolver": "workspace:*",
    "@kybernesis/arp-spec": "workspace:*",
    "@kybernesis/arp-templates": "workspace:*",
    "@kybernesis/arp-tls": "workspace:*",
    "@kybernesis/arp-transport": "workspace:*",
    "@noble/ed25519": "^2.2.3",
    "@simplewebauthn/server": "^13.3.0",
    "better-sqlite3": "^11.5.0",
    "hono": "^4.6.12"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11"
  }
}
