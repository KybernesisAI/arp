{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://arp.spec/schema/revocations/v0.1.json",
  "title": "revocations",
  "type": "object",
  "properties": {
    "issuer": {
      "type": "string",
      "pattern": "^did:[a-z0-9]+:[A-Za-z0-9._:%-]+$",
      "description": "Principal DID issuing the list"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "revocations": {
      "type": "array",
      "items": {
        "anyOf": [
          {
            "type": "object",
            "properties": {
              "type": {
                "type": "string",
                "const": "connection"
              },
              "id": {
                "type": "string",
                "minLength": 1,
                "description": "Connection ID (e.g. \"conn_7a3f...\")"
              },
              "revoked_at": {
                "type": "string",
                "format": "date-time"
              },
              "reason": {
                "type": "string",
                "description": "Machine-readable reason code (e.g. \"user_requested\")"
              }
            },
            "required": [
              "type",
              "id",
              "revoked_at"
            ],
            "additionalProperties": false
          },
          {
            "type": "object",
            "properties": {
              "type": {
                "type": "string",
                "const": "key"
              },
              "fingerprint": {
                "type": "string",
                "pattern": "^sha256:[0-9a-f]{8,}$",
                "description": "SHA-256 of the public key"
              },
              "revoked_at": {
                "type": "string",
                "format": "date-time"
              },
              "reason": {
                "type": "string"
              }
            },
            "required": [
              "type",
              "fingerprint",
              "revoked_at"
            ],
            "additionalProperties": false
          }
        ]
      }
    },
    "signature": {
      "type": "object",
      "properties": {
        "alg": {
          "type": "string",
          "const": "EdDSA"
        },
        "kid": {
          "type": "string",
          "minLength": 1,
          "description": "Signing key reference (e.g. \"did:web:ian.self.xyz#key-1\")"
        },
        "value": {
          "type": "string",
          "minLength": 1,
          "description": "Base64url-encoded signature bytes"
        }
      },
      "required": [
        "alg",
        "kid",
        "value"
      ],
      "additionalProperties": false
    }
  },
  "required": [
    "issuer",
    "updated_at",
    "revocations",
    "signature"
  ],
  "additionalProperties": false
}
