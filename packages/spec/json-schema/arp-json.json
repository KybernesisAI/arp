{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://arp.spec/schema/arp-json/v0.1.json",
  "title": "arp-json",
  "type": "object",
  "properties": {
    "version": {
      "type": "string",
      "description": "ARP protocol version (e.g. \"0.1\")"
    },
    "capabilities": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1,
      "description": "Capability tokens advertised (e.g. \"didcomm-v2\", \"cedar-pdp\", \"ucan-tokens\")"
    },
    "scope_catalog_url": {
      "type": "string",
      "format": "uri",
      "description": "HTTPS URL of the scope catalog JSON this agent honours"
    },
    "policy_schema_url": {
      "type": "string",
      "format": "uri",
      "description": "HTTPS URL of the Cedar policy schema"
    }
  },
  "required": [
    "version",
    "capabilities",
    "scope_catalog_url",
    "policy_schema_url"
  ],
  "additionalProperties": false
}
