{
  "name": "@kybernesis/arp",
  "version": "0.3.0",
  "description": "ARP CLI — one command to connect a local agent (KyberBot, OpenClaw, Hermes, etc.) to ARP Cloud. Auto-detects the agent framework + handoff from the current directory.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KybernesisAI/arp.git",
    "directory": "packages/arp"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "bin": {
    "arp": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@kybernesis/arp-cloud-bridge": "^0.1.1",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.9.0",
    "tsup": "^8.3.5",
    "typescript": "~5.5.4",
    "vitest": "^2.1.5"
  }
}
