{
  "name": "@kybernesis/arp-create-adapter",
  "version": "0.1.0",
  "description": "Scaffolds a conformance-passing ARP framework adapter in TypeScript or Python.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/KybernesisAI/arp.git",
    "directory": "packages/create-adapter"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "bin": {
    "create-arp-adapter": "./dist/cli.js"
  },
  "files": [
    "dist",
    "templates",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "handlebars": "^4.7.8"
  },
  "devDependencies": {
    "@types/node": "^22.9.0"
  }
}
