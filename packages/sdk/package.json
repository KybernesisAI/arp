{
  "name": "@kybernesis/arp-sdk",
  "version": "0.1.2",
  "description": "ARP SDK — high-level ArpAgent wrapping runtime/pdp/transport/registry/audit. The developer-facing entry point for custom agents.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/KybernesisAI/arp.git",
    "directory": "packages/sdk"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests"
  },
  "dependencies": {
    "@kybernesis/arp-audit": "workspace:*",
    "@kybernesis/arp-pdp": "workspace:*",
    "@kybernesis/arp-registry": "workspace:*",
    "@kybernesis/arp-resolver": "workspace:*",
    "@kybernesis/arp-runtime": "workspace:*",
    "@kybernesis/arp-spec": "workspace:*",
    "@kybernesis/arp-transport": "workspace:*",
    "@noble/ed25519": "^2.2.3"
  },
  "devDependencies": {
    "@types/node": "^22.9.0"
  }
}
