# apps/cloud — environment variables template.
#
# Copy to `.env.local` for development. Never commit `.env.local` (it's in
# .gitignore). In production every value below goes into Vercel's env var
# store; secrets are marked as sensitive.

# ---------------------------------------------------------------- cloud core
# HMAC secret for the session cookie. Rotate rarely — rotation logs every user
# out. 32+ bytes random, base64 or hex.
ARP_CLOUD_SESSION_SECRET="change-me-32-bytes-of-random-hex"

# Public hostname the cloud UI serves on. Controls CORS, cookie Secure flag,
# and redirect URLs.
ARP_CLOUD_HOST="cloud.arp.run"

# Public wss:// URL of the cloud gateway that agents connect to. Defaults to a
# local ws://localhost:3001/ws in dev.
ARP_CLOUD_WS_PUBLIC_URL="wss://cloud.arp.run/ws"

# Pre-shared key for `POST /internal/registrar/bind`. Delivered out-of-band to
# v2.1-conformant registrars (Headless is the only one as of Phase 9b).
# Rotate at launch. 32+ bytes random, base64url or hex.
#
# Generate locally with: openssl rand -base64url 32
ARP_CLOUD_REGISTRAR_PSK=""

# ------------------------------------------------------------------- storage
# Neon Postgres connection string. When set, the cloud app uses the Neon HTTP
# driver. When empty, the app falls back to in-process PGlite (dev + tests).
DATABASE_URL=""

# Optional: persist PGlite to disk in dev. No effect when DATABASE_URL is set.
# PGLITE_DATA_DIR=".pglite"

# -------------------------------------------------------------------- Stripe
# Sandbox/live Stripe keys. Leave empty to disable billing (webhook + checkout
# routes return 503 / no-op). Rotate sandbox → live at Phase 9 production flip.
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_PRO=""
STRIPE_PRICE_TEAM=""

# ---------------------------------------------------------------- cross-surface
# The spec.arp.run project host. Used for cross-linking from the cloud surface.
APP_ARP_SPEC_HOST="spec.arp.run"

# ---------------------------------------------------------------- WebAuthn (9d)
# Relying-party ID for passkey registration + sign-in. Must be the apex
# domain so a single passkey registration works across arp.run,
# cloud.arp.run, and app.arp.run. Override to `localhost` for local HTTP
# dev — WebAuthn requires HTTPS everywhere except localhost.
WEBAUTHN_RP_ID="arp.run"

# Human-readable name shown by the authenticator prompt
# ("Save passkey for …?").
WEBAUTHN_RP_NAME="ARP"

# Comma-separated list of allowed origins the WebAuthn ceremony may come
# from. Include every surface the sign-in page can be served from.
WEBAUTHN_ORIGINS="https://arp.run,https://cloud.arp.run,https://app.arp.run,http://localhost:3000"

# --------------------------------------------------------------------- tests
# Colon-separated `principal_did=publicKeyMultibase` pairs for sidecar
# migration flows in dev + tests. Leave empty in production — Phase-8.5
# did:key principals decode their own pubkey without the fixture path.
# ARP_CLOUD_PRINCIPAL_FIXTURES=""
